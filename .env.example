# Spine environment template.
# Copy to `.env` (already gitignored) and override values for your environment.
# Do NOT commit `.env`.

# --- Primary database ---
# Required in production. Used by `spine serve` and `spine migrate`.
POSTGRES_USER=spine
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=spine

# --- Registry database (shared workspace mode only) ---
POSTGRES_REGISTRY_USER=spine_registry
POSTGRES_REGISTRY_PASSWORD=change-me-in-production
POSTGRES_REGISTRY_DB=spine_registry

# --- Test databases ---
# Only needed when running `docker compose -f docker-compose.test.yaml up`.
POSTGRES_TEST_USER=spine_test
POSTGRES_TEST_PASSWORD=spine_test
POSTGRES_TEST_DB=spine_test
POSTGRES_TEST_REGISTRY_USER=spine_registry_test
POSTGRES_TEST_REGISTRY_PASSWORD=spine_registry_test
POSTGRES_TEST_REGISTRY_DB=spine_registry_test

# --- Git HTTP trusted networks ---
# Comma-separated CIDR list. Clients whose source IP falls inside one of
# these ranges may clone/fetch without a bearer token. Leave empty (the
# new default) to require tokens from every client. Set this only to the
# narrow subnet your runner containers actually use (e.g. the Docker
# compose network for runners), never to the full RFC1918 space.
# Example — runner network only:
#   SPINE_GIT_HTTP_TRUSTED_CIDRS=172.28.0.0/16
# SPINE_GIT_HTTP_TRUSTED_CIDRS=

# --- Runtime environment ---
# Accepted values: production, staging, development. Any other value
# (or leaving this unset) is treated as "unspecified". When set to
# "production", SPINE_DEV_MODE is refused at startup — the dev-mode
# auth bypass MUST NOT be used in production.
# SPINE_ENV=development

# --- Dev-mode auth bypass ---
# Set to 1 (or "true") to allow unauthenticated requests through
# authorize(). Development convenience only; refused when
# SPINE_ENV=production. Leave unset for any real deployment.
# SPINE_DEV_MODE=

# --- Rate-limiter trusted proxies ---
# When Spine sits behind a reverse proxy (load balancer, CDN), set this
# to the proxy's CIDR so the rate limiter keys on the real client IP
# from X-Forwarded-For instead of the shared proxy address. Leaving
# this unset preserves the RemoteAddr-only behavior and is the right
# choice when the server is directly internet-facing — naive XFF
# trust would let any client forge a source IP to evade the limiter.
# Example: SPINE_TRUSTED_PROXY_CIDRS=10.0.0.0/8
# SPINE_TRUSTED_PROXY_CIDRS=

# --- Git push authentication ---
# Two modes are supported; the credential helper is the recommended
# production mode. If both are set, the helper wins and the token is
# ignored with a warning at startup.
#
# 1) Credential helper (recommended) — lets git retrieve the token
#    from the OS keychain / system secret store. The helper name must
#    be one of: cache, store, osxkeychain, manager, pass.
#    Example: SPINE_GIT_CREDENTIAL_HELPER=osxkeychain
# SPINE_GIT_CREDENTIAL_HELPER=
#
# 2) Environment-provided token — spine reads SPINE_GIT_PUSH_TOKEN at
#    startup, copies it into an in-memory GIT_ASKPASS helper, and then
#    scrubs the variable from os.Environ() so it is no longer visible
#    to child processes, /proc/<pid>/environ, or core dumps. This is a
#    step up from leaving it in the environment but the credential
#    helper above is preferable where available.
# SPINE_GIT_PUSH_TOKEN=
# SPINE_GIT_PUSH_USERNAME=x-access-token

# --- Secret encryption key ---
# Base64-encoded 32-byte key used to encrypt at-rest secrets (today:
# webhook signing_secret). Required when SPINE_ENV=production; without
# it, a database compromise would hand an attacker the ability to forge
# webhook payloads. Generate one with:
#   openssl rand -base64 32
# Rows written without a key remain plaintext and are transparently
# re-encrypted on the next UpdateSubscription call once the key is set.
# Losing the key means existing ciphertext rows cannot be decrypted; back
# it up alongside your other production secrets.
# SPINE_SECRET_ENCRYPTION_KEY=

# --- Operator token ---
# Static bearer token for system-level endpoints (workspace CRUD, etc.).
# Minimum length is 32 characters; spine serve refuses to start with a
# shorter value. Generate one with `openssl rand -hex 32`.
# Leave unset to return 503 on operator endpoints (for deployments that
# don't expose the operator surface at all).
# SPINE_OPERATOR_TOKEN=

# --- Insecure-local acknowledgement ---
# Set to 1 ONLY for local development with sslmode=disable connection URLs.
# Production deployments must leave this unset and use sslmode=require
# (or stronger). `docker-compose.yaml` sets this for the bundled local
# environment; do not set it in any real deployment.
# SPINE_INSECURE_LOCAL=1
